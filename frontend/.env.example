# ─────────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────────

# URL of the backend service, used by the Vite dev server proxy.
# Must match the Docker backend service name and port.
BACKEND_URL=<docker-backend-service-url>

# Google OAuth 2.0 client ID (VITE_ prefix exposes it to browser code).
# Must match the GOOGLE_CLIENT_ID in backend/.env.
VITE_GOOGLE_CLIENT_ID=<your-google-client-id>
