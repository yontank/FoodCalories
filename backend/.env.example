# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────

# Set to true to run with python3 main.py (hot-reload, verbose errors).
# Set to false (or omit) to run with gunicorn in production mode.
DEBUG=false

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────

# Full SQLAlchemy connection string.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret key used for JWT signing. Must be at least 32 characters.
SECRET_KEY=your-secret-key-at-least-32-characters-long


# ─────────────────────────────────────────────
# Optional — only needed when running PostgreSQL locally
# ─────────────────────────────────────────────

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=dbname
