# ─────────────────────────────────────────────
# Backend
# ─────────────────────────────────────────────

# Full SQLAlchemy connection string.
# The host must match the Docker service name (e.g. "foodcalories_db").
# The user, password, and db must match the values in the root .env file.
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<dbname>

# Secret key used for JWT signing. Must be at least 32 characters.
# Generate one with: openssl rand -hex 32
SECRET_KEY=<your-secret-key>

# Google OAuth 2.0 client ID for authentication.
# Obtain from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=<your-google-client-id>

# ─────────────────────────────────────────────
# Optional overrides (set in docker-compose environment)
# ─────────────────────────────────────────────

# DEBUG=true          # Set via docker-compose, not here.
# CORS_ORIGIN=["http://localhost:5173"]  # Defaults to localhost:5173.
