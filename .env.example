# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────

# Full connection string used by the backend to connect to PostgreSQL.
# The host must match the Docker service name (e.g. "db" in docker-compose).
DATABASE_URL=postgresql://<user>:<password>@db:5432/<dbname>

# PostgreSQL container credentials.
# These must match the values in DATABASE_URL above.
POSTGRES_USER=<your-db-user>
POSTGRES_PASSWORD=<your-db-password>
POSTGRES_DB=<your-db-name>

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────

# Secret key used for signing tokens / sessions. Use a long random string in production.
# Generate one with: openssl rand -hex 32
SECRET_KEY=<your-secret-key>

# Set to true to enable debug mode (verbose errors). Never enable in production.
# Currently set inside docker-compose environment variables.
DEBUG=false

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────

# JSON array of allowed origins for cross-origin requests.
# Add your frontend URL here (e.g. https://yourdomain.com).
CORS_ORIGIN=["http://localhost:5173"]

# ─────────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────────

# URL of the backend service, used by the dev server proxy.
# In Docker dev: use the Docker service name (e.g. http://foodcalories_backend:8000).
# In local dev:  use http://127.0.0.1:8000
# Not used in production (nginx handles proxying).
BACKEND_URL=http://127.0.0.1:8000
